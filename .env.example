# ===== DATABASE =====
# Get this from Render Postgres dashboard -> "External Database URL" or "Internal Database URL"
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== BOT CONFIG =====
# Comma-separated phone numbers (with country code, no +, no spaces) who get admin commands
ADMIN_NUMBERS=15551234567,15557654321

# Prefix for bot commands, e.g. with "!" a command looks like "!menu"
COMMAND_PREFIX=!

# Bot display name used in some replies
BOT_NAME=MyBot

# ===== STATUS (STORY) FEATURE =====
# If "true", the bot automatically views (marks as seen) every contact's status update
AUTO_VIEW_STATUS=true
# If "true", the bot downloads media from statuses it sees into ./downloads/statuses
AUTO_DOWNLOAD_STATUS=false
# If "true", the bot automatically reacts to every status with an emoji chosen from its caption
AUTO_REACT_STATUS=false
# Random delay range (ms) before reacting, so it doesn't look instant/robotic
STATUS_REACT_DELAY_MIN_MS=1500
STATUS_REACT_DELAY_MAX_MS=5000

# ===== AUTO-REPLY =====
# Minutes between auto-replies to the same sender, so it doesn't repeat on every message
AUTO_REPLY_COOLDOWN_MINUTES=60

# ===== BROADCAST / RATE LIMITING =====
# Milliseconds to wait between each message when broadcasting to many people (avoid bans)
BROADCAST_DELAY_MS=2000

# ===== SERVER =====
PORT=3000

# ===== KEEP-ALIVE (prevents Render free tier from sleeping) =====
# Set this to your Render service's public URL to enable self-pinging.
# Leave unset for local development.
SELF_PING_URL=https://your-service-name.onrender.com
# How often to ping, in milliseconds (default: 10 minutes)
SELF_PING_INTERVAL_MS=600000

# ===== LOGGING =====
LOG_LEVEL=info
