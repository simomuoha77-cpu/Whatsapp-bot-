# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== YOUR PLATFORM ADMIN LOGIN =====
# This is YOUR login to the master dashboard at /admin — clients never see this.
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD=choose-a-strong-password
# Random secret signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# ===== BOT BEHAVIOR DEFAULTS =====
COMMAND_PREFIX=!
BOT_NAME=Bot

# Random delay range (ms) before reacting to statuses, so it doesn't look robotic
STATUS_REACT_DELAY_MIN_MS=1500
STATUS_REACT_DELAY_MAX_MS=5000

# Minutes between auto-replies to the same contact (per bot)
AUTO_REPLY_COOLDOWN_MINUTES=60

# Delay between messages during a broadcast (ms) — avoid bans
BROADCAST_DELAY_MS=2000

# ===== AI CHAT ASSISTANT (optional) =====
# Only needed if you enable the AI Chat Assistant feature for a client bot.
# You can set one or both — pick which provider per-bot in the dashboard.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== M-PESA DARAJA (STK PUSH BILLING) =====
# From your Safaricom Daraja app dashboard.
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
# 'sandbox' for testing, 'production' for real M-Pesa transactions
DARAJA_ENV=sandbox

# ===== SERVER =====
PORT=3000
LOG_LEVEL=info
